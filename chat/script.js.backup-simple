// ======================== CONFIGURACIÓN DE IA AVANZADA ========================
let MAX_MESSAGES_PER_CHAT = 70;
const RESET_LIMIT_MINUTES = 30;
const AVISO_ACTIVO = true;
const AVISO_TITULO = "¡DevCenter IA Mejorado!";
const AVISO_DESCRIPCION = "🎉 Versión mejorada con todas las funciones avanzadas de IA-COPIAR integradas en ChatGPT. ¡Disfruta!";

let TEMPERATURE = 0.7;
let TOP_K = 40;
let TOP_P = 0.9;

let MAX_OUTPUT_TOKENS_INFO = 3000;
let MAX_OUTPUT_TOKENS_MEMORY = 5000;
let MAX_OUTPUT_TOKENS_PROGRAM = 90000;
let MAX_OUTPUT_TOKENS_IMAGE = 4000;

let responseMode = localStorage.getItem('responseMode') || 'media';
let activeAbility = localStorage.getItem('activeAbility') || 'info';

// ======================== ESTADO DEL CHAT ========================
let chatHistory = [];
let currentChatId = null;
let allChats = [];
let isGenerating = false;

// ======================== ELEMENTOS DEL DOM ========================
const chatMessages = document.getElementById('chatMessages');
const chatInput = document.getElementById('chatInput');
const chatForm = document.getElementById('chatForm');
const chatHistory_el = document.getElementById('chatHistory');
const newChatBtn = document.getElementById('newChatBtn');
const backBtn = document.getElementById('backBtn');
const sendBtn = document.documentElement.querySelector('button[type="submit"]') || 
                document.querySelector('form button');

// ======================== INICIALIZACIÓN ========================
document.addEventListener('DOMContentLoaded', () => {
    setupEventListeners();
    loadChatsFromStorage();
    loadChatFromURL();
    chatInput.focus();
});

function setupEventListeners() {
    // Enviar con Enter
    chatInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendBtn?.click();
        }
    });

    // Event listeners principales
    if (chatForm) chatForm.addEventListener('submit', handleSendMessage);
    if (newChatBtn) newChatBtn.addEventListener('click', createNewChat);
    if (backBtn) backBtn.addEventListener('click',() => window.location.href = '/');
    
    // Auto-resize textarea
    chatInput.addEventListener('input', () => {
        chatInput.style.height = 'auto';
        chatInput.style.height = Math.min(chatInput.scrollHeight, 150) + 'px';
    });

    // Comprobar si hay primer mensaje
    const firstMessage = localStorage.getItem('devcenter_first_message');
    if (firstMessage) {
        chatInput.value = firstMessage;
        chatInput.style.height = Math.min(chatInput.scrollHeight, 150) + 'px';
        localStorage.removeItem('devcenter_first_message');
        
        setTimeout(() => {
            chatForm?.dispatchEvent(new Event('submit', { bubbles: true }));
        }, 300);
    }
}

// ======================== GESTIÓN DE CHATS ========================
function loadChatFromURL() {
    const params = new URLSearchParams(window.location.search);
    const chatId = params.get('id');
    
    if (chatId && allChats.find(c => c.id == chatId)) {
        const chat = allChats.find(c => c.id == chatId);
        currentChatId = allChats.indexOf(chat);
        chatHistory = chat.messages || [];
        renderMessages();
    } else if (allChats.length === 0) {
        createNewChat();
    } else {
        currentChatId = 0;
        chatHistory = allChats[0].messages || [];
        renderMessages();
    }
    
    updateChatList();
}

function createNewChat() {
    const newChat = {
        id: Date.now(),
        title: 'Nuevo chat',
        messages: [],
        created: new Date().toISOString()
    };
    
    allChats.push(newChat);
    currentChatId = allChats.length - 1;
    chatHistory = [];
    window.history.pushState({}, '', `/chat?id=${newChat.id}`);
    saveChatsToStorage();
    renderMessages();
    updateChatList();
    chatInput.focus();
}

function deleteChat(index) {
    if (confirm(`¿Eliminar este chat?`)) {
        allChats.splice(index, 1);
        if (currentChatId === index) {
            currentChatId = Math.max(0, allChats.length - 1);
            chatHistory = allChats[currentChatId]?.messages || [];
        }
        saveChatsToStorage();
        updateChatList();
        renderMessages();
        if (allChats.length === 0) createNewChat();
    }
}

function editChatTitle(index) {
    const newTitle = prompt('Nuevo título:', allChats[index].title);
    if (newTitle?.trim()) {
        allChats[index].title = newTitle.trim();
        saveChatsToStorage();
        updateChatList();
    }
}

// ======================== ENVÍO DE MENSAJES ========================
async function handleSendMessage(e) {
    e.preventDefault();
    
    const message = chatInput.value.trim();
    if (!message || isGenerating) return;
    
    // Agregar mensaje del usuario
    chatHistory.push({
        role: 'user',
        content: message,
        timestamp: new Date().toISOString()
    });
    
    // Actualizar título si es primer mensaje
    if (chatHistory.length === 1) {
        allChats[currentChatId].title = message.substring(0, 40) + (message.length > 40 ? '...' : '');
    }
    
    allChats[currentChatId].messages = chatHistory;
    saveChatsToStorage();
    chatInput.value = '';
    chatInput.style.height = 'auto';
    renderMessages();
    
    if (sendBtn) sendBtn.disabled = true;
    addTypingIndicator();
    isGenerating = true;
    
    try {
        // Construir historial para API
        const conversationHistory = chatHistory.slice(0, -1).map(msg => ({
            role: msg.role === 'ai' ? 'model' : msg.role,
            content: msg.content
        }));
        
        const response = await fetch('/api/gemini', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                message: message,
                mode: activeAbility || 'chat',
                conversationHistory: conversationHistory
            })
        });
        
        if (!response.ok) {
            throw new Error(`Error ${response.status}: ${response.statusText}`);
        }
        
        const data = await response.json();
        const reply = data.reply || data.response || data.text;
        
        if (!reply) {
            throw new Error('No response from AI');
        }
        
        removeTypingIndicator();
        
        // Agregar respuesta
        chatHistory.push({
            role: 'ai',
            content: reply,
            timestamp: new Date().toISOString()
        });
        
        allChats[currentChatId].messages = chatHistory;
        saveChatsToStorage();
        renderMessages();
        scrollToBottom();
        
    } catch (error) {
        console.error('Error:', error);
        removeTypingIndicator();
        
        chatHistory.push({
            role: 'ai',
            content: `❌ Error: ${error.message}`,
            timestamp: new Date().toISOString()
        });
        
        renderMessages();
    } finally {
        isGenerating = false;
        if (sendBtn) sendBtn.disabled = false;
        chatInput.focus();
    }
}

// ======================== RENDERIZADO DE MENSAJES ========================
function renderMessages() {
    if (!chatMessages) return;
    
    chatMessages.innerHTML = '';
    
    chatHistory.forEach((msg, index) => {
        const messageEl = document.createElement('div');
        messageEl.className = `message ${msg.role}`;
        
        const contentEl = document.createElement('div');
        contentEl.className = 'message-content';
        contentEl.innerHTML = escapeHtml(msg.content);
        
        messageEl.appendChild(contentEl);
        
        // Acciones solo para mensajes del usuario
        if (msg.role === 'user') {
            const actionsEl = document.createElement('div');
            actionsEl.className = 'message-actions';
            
            // Botón copiar
            const copyBtn = document.createElement('button');
            copyBtn.className = 'message-action-btn';
            copyBtn.innerHTML = '📋';
            copyBtn.title = 'Copiar';
            copyBtn.addEventListener('click', () => {
                navigator.clipboard.writeText(msg.content);
                copyBtn.innerHTML = '✅';
                setTimeout(() => { copyBtn.innerHTML = '📋'; }, 1500);
            });
            
            // Botón editar
            const editBtn = document.createElement('button');
            editBtn.className = 'message-action-btn';
            editBtn.innerHTML = '✏️';
            editBtn.title = 'Editar';
            editBtn.addEventListener('click', () => {
                const newContent = prompt('Editar mensaje:', msg.content);
                if (newContent?.trim()) {
                    chatHistory[index].content = newContent.trim();
                    allChats[currentChatId].messages = chatHistory;
                    saveChatsToStorage();
                    renderMessages();
                }
            });
            
            // Botón eliminar
            const deleteBtn = document.createElement('button');
            deleteBtn.className = 'message-action-btn delete';
            deleteBtn.innerHTML = '🗑️';
            deleteBtn.title = 'Eliminar';
            deleteBtn.addEventListener('click', () => {
                if (confirm('¿Eliminar este mensaje?')) {
                    chatHistory.splice(index, 1);
                    allChats[currentChatId].messages = chatHistory;
                    saveChatsToStorage();
                    renderMessages();
                }
            });
            
            actionsEl.appendChild(copyBtn);
            actionsEl.appendChild(editBtn);
            actionsEl.appendChild(deleteBtn);
            messageEl.appendChild(actionsEl);
        }
        
        chatMessages.appendChild(messageEl);
    });
    
    scrollToBottom();
}

// ======================== UTILIDADES ========================
function addTypingIndicator() {
    if (!chatMessages) return;
    
    const messageEl = document.createElement('div');
    messageEl.className = 'message ai typing';
    messageEl.id = 'typingIndicator';
    messageEl.innerHTML = `
        <div class="message-content">
            <div class="typing-indicator">
                <span class="typing-dot"></span>
                <span class="typing-dot"></span>
                <span class="typing-dot"></span>
            </div>
        </div>
    `;
    chatMessages.appendChild(messageEl);
    scrollToBottom();
}

function removeTypingIndicator() {
    const indicator = document.getElementById('typingIndicator');
    if (indicator) indicator.remove();
}

function scrollToBottom() {
    setTimeout(() => {
        if (chatMessages) {
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }
    }, 0);
}

function updateChatList() {
    if (!chatHistory_el) return;
    
    chatHistory_el.innerHTML = '';
    
    allChats.forEach((chat, index) => {
        const containerEl = document.createElement('div');
        containerEl.className = 'chat-item';
        if (index === currentChatId) {
            containerEl.style.background = 'var(--message-user)';
        }
        
        const titleEl = document.createElement('span');
        titleEl.className = 'chat-item-text';
        titleEl.textContent = chat.title || 'Sin título';
        titleEl.title = chat.title;
        
        const actionsEl = document.createElement('div');
        actionsEl.className = 'chat-item-actions';
        
        const editBtn = document.createElement('button');
        editBtn.className = 'chat-item-btn';
        editBtn.innerHTML = '✏️';
        editBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            editChatTitle(index);
        });
        
        const deleteBtn = document.createElement('button');
        deleteBtn.className = 'chat-item-btn delete';
        deleteBtn.innerHTML = '🗑️';
        deleteBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            deleteChat(index);
        });
        
        actionsEl.appendChild(editBtn);
        actionsEl.appendChild(deleteBtn);
        
        containerEl.appendChild(titleEl);
        containerEl.appendChild(actionsEl);
        
        containerEl.addEventListener('click', () => {
            currentChatId = index;
            chatHistory = chat.messages || [];
            window.history.pushState({}, '', `/chat?id=${chat.id}`);
            renderMessages();
            saveChatsToStorage();
            updateChatList();
            chatInput.focus();
        });
        
        chatHistory_el.appendChild(containerEl);
    });
}

function escapeHtml(text) {
    const map = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;'
    };
    return text.replace(/[&<>"']/g, m => map[m]);
}

// ======================== PERSISTENCIA ========================
function saveChatsToStorage() {
    allChats[currentChatId].messages = chatHistory;
    localStorage.setItem('devcenter_chats', JSON.stringify(allChats));
}

function loadChatsFromStorage() {
    try {
        const saved = localStorage.getItem('devcenter_chats');
        allChats = saved ? JSON.parse(saved) : [];
    } catch (e) {
        console.error('Error loading chats:', e);
        allChats = [];
    }
}

console.log('✅ Chat script (v2) loaded');
